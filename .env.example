# ═══════════════════════════════════════════════
# Django
# ═══════════════════════════════════════════════
DJANGO_SECRET_KEY=your-secret-key-change-in-production
DJANGO_SETTINGS_MODULE=config.settings.development
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ═══════════════════════════════════════════════
# Database
# ═══════════════════════════════════════════════
DATABASE_URL=postgres://postgres:postgres@postgres:5432/accounting_dev
DB_NAME=accounting_dev
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=postgres
DB_PORT=5432

# ═══════════════════════════════════════════════
# Redis
# ═══════════════════════════════════════════════
REDIS_URL=redis://redis:6379/0

# ═══════════════════════════════════════════════
# Razorpay (use test keys for development)
# ═══════════════════════════════════════════════
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx
RAZORPAY_WEBHOOK_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# ═══════════════════════════════════════════════
# Email (console backend for dev — prints to terminal)
# ═══════════════════════════════════════════════
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@yourapp.com

# ═══════════════════════════════════════════════
# Next.js
# ═══════════════════════════════════════════════
NEXT_PUBLIC_API_URL=http://localhost:8000/api
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx

# ═══════════════════════════════════════════════
# Plan limits — Free / Starter / Pro / Business
# ═══════════════════════════════════════════════
FREE_INVOICE_LIMIT=25
STARTER_INVOICE_LIMIT=100
PRO_INVOICE_LIMIT=9999
BUSINESS_INVOICE_LIMIT=9999

FREE_EXPENSE_LIMIT=50
STARTER_EXPENSE_LIMIT=200
PRO_EXPENSE_LIMIT=9999
BUSINESS_EXPENSE_LIMIT=9999

FREE_USER_LIMIT=1
STARTER_USER_LIMIT=3
PRO_USER_LIMIT=5
BUSINESS_USER_LIMIT=15

FREE_COMPANY_LIMIT=1
STARTER_COMPANY_LIMIT=2
PRO_COMPANY_LIMIT=5
BUSINESS_COMPANY_LIMIT=9999
